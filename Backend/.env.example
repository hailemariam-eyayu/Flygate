# Backend environment variables
# Copy this file to .env and fill in the values

PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Flygate
shortCodeT=526341
shortCodeP=586828
merchant_id=EM
BASE_URL=https://ethiopiangatewaytest.azurewebsites.net/

# CBS (FLEXCUBE)
cbs_user=ADCUSER
cbs_pass=your_cbs_password
cbs_url=http://10.1.22.100:7003/FCUBSRTService/FCUBSRTService?WSDL

# Airline account number for CBS offset
airlineAccountNumber=your_airline_account_number
